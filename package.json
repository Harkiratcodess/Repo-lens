{
  "name": "repo-lens",
  "displayName": "RepoLens - Codebase Navigator",
  "description": "Instantly understand any codebase — RepoLens maps every file and folder so you can contribute with confidence.",
  "version": "1.0.1",
  "publisher": "Harkiratcodess",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repo-lens.analyze",
        "title": "RepoLens: Analyze Codebase"
      }
    ],
    "configuration": {
      "title": "RepoLens",
      "properties": {
        "repolens.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Your free Groq API key from https://console.groq.com"
        },
        "repolens.ignoreFolders": {
          "type": "array",
          "default": [
            "node_modules",
            ".git",
            "dist",
            "build",
            ".next",
            "out",
            "coverage",
            ".cache",
            "vendor"
          ],
          "description": "Folders to skip during analysis"
        },
        "repolens.maxFileSizeKB": {
          "type": "number",
          "default": 100,
          "description": "Skip files larger than this size (in KB)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo ready"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0"
  }
}
